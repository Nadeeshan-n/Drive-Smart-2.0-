        xmlns:local="clr-namespace:Drive_Smart_2._0"
        mc:Ignorable="d"
        Title="MainWindow" Height="1080" Width="1920">
    <Grid Margin="10,0,0,-6">
        <Grid.RowDefinitions>
            <RowDefinition Height="256*"/>
            <RowDefinition Height="239.009"/>
            <RowDefinition Height="531*"/>
            <RowDefinition Height="44*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0*"/>
            <ColumnDefinition Width="0*"/>
            <ColumnDefinition Width="0*"/>
            <ColumnDefinition Width="90*"/>
            <ColumnDefinition Width="411*"/>
            <ColumnDefinition Width="161*"/>
            <ColumnDefinition Width="0*"/>
            <ColumnDefinition Width="0*"/>
            <ColumnDefinition Width="1248*"/>
        </Grid.ColumnDefinitions>
        <Image Grid.Column="5" Margin="108,-6,607,392" Grid.RowSpan="3" Source="/ChatGPT Image May 29, 2026, 04_00_19 PM.png" Stretch="Fill" Grid.ColumnSpan="4"/>
        <Rectangle Grid.Column="2" HorizontalAlignment="Left" Height="131" Margin="4,2,0,0" Grid.Row="2" Stroke="#FFC9D9FB" VerticalAlignment="Top" Width="1900" Grid.ColumnSpan="7" Fill="#FF01152E"/>

        <Label Grid.Column="2" Content="- - - - - - - - DRIVE SMART - - - - - - - -" HorizontalAlignment="Left" Margin="32,239,0,398" Grid.Row="1" FontSize="100" Grid.ColumnSpan="7" FontFamily="Tahoma" FontWeight="Bold" Foreground="#FFFFFEFE" Background="{x:Null}" Grid.RowSpan="2" Width="1848"/>
