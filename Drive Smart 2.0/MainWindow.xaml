        <Label Grid.Column="6" Content="Vehicle Rental Company" HorizontalAlignment="Left" Margin="105,144,0,0" Grid.Row="2" VerticalAlignment="Top" FontFamily="Tahoma" FontSize="36" FontStyle="Italic" Grid.ColumnSpan="3"/>
        <Button x:Name="systemstartButton" Grid.Column="6" Content="Start" HorizontalAlignment="Left" Margin="113,337,0,0" Grid.Row="2" VerticalAlignment="Top" FontFamily="Tahoma" FontSize="48" Width="361" Height="68" Background="#FF1361F0" Foreground="#FFFFFEFE" FontWeight="Bold" Click="systemstartButton_Click" Grid.ColumnSpan="3"/>

    </Grid>
