<Window x:Class="Drive_Smart_2._0.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Drive Smart 2.0"
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        FontFamily="Segoe UI"
        Background="#F5F7FA"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <Style x:Key="TileStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E3EAF3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#1565C0"/>
                                <Setter TargetName="Bd" Property="Background" Value="#F0F6FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E3EEFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="110"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="64"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Background="#1565C0">
            <StackPanel HorizontalAlignment="Center"
            VerticalAlignment="Center">

                <TextBlock Text="🚗 DRIVE SMART"
               FontSize="28"
               FontWeight="Bold"
               Foreground="White"
               HorizontalAlignment="Center"/>

                <TextBlock Text="Vehicle Rental Management System"
               FontSize="14"
               Foreground="#BBDEFB"
               HorizontalAlignment="Center"
               Margin="0,6,0,0"/>

                <TextBlock x:Name="TxtWelcome"
               Text="Welcome Back, John Smith"
               FontSize="16"
               FontWeight="SemiBold"
               Foreground="White"
               Margin="0,10,0,0"
               HorizontalAlignment="Center"/>

                <TextBlock x:Name="TxtRoleHeader"
               Text="System Administrator"
               FontSize="13"
               Foreground="#E3F2FD"
               HorizontalAlignment="Center"/>

                <TextBlock x:Name="TxtHeaderDateTime"
               FontSize="12"
               Foreground="#BBDEFB"
               HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── Tile Grid ── -->
        <UniformGrid Grid.Row="1"
                     Rows="2" Columns="4"
                     Margin="40,28,40,28">

            <!-- Dashboard -->
            <Button x:Name="BtnDashboard" Style="{StaticResource TileStyle}" Click="BtnDashboard_Click_1"
                    
                    >
                <StackPanel HorizontalAlignment="Center">
                    <Border Width="64" Height="64" CornerRadius="16"
                            Background="#E6F1FB" Margin="0,0,0,12"
                            HorizontalAlignment="Center">
                        <TextBlock Text="📊" FontSize="30"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Dashboard" FontSize="15"
                               FontWeight="SemiBold" Foreground="#111827"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Stats and overview" FontSize="12"
                               Foreground="#6B7280" Margin="0,4,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Employees -->
            <Button x:Name="BtnEmployees"
                    Style="{StaticResource TileStyle}"
                    Margin="8" Click="BtnEmployees_Click"
                    >
                <StackPanel HorizontalAlignment="Center">
                    <Border Width="64" Height="64" CornerRadius="16"
                            Background="#EEEDFE" Margin="0,0,0,12"
                            HorizontalAlignment="Center">
                        <TextBlock Text="👤" FontSize="30"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Employees" FontSize="15"
                               FontWeight="SemiBold" Foreground="#111827"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Manage staff accounts" FontSize="12"
                               Foreground="#6B7280" Margin="0,4,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Vehicles -->
            <Button x:Name="BtnVehicles"
                    Style="{StaticResource TileStyle}"
                    Margin="8" Click="BtnVehicles_Click"
                    >
                <StackPanel HorizontalAlignment="Center">
                    <Border Width="64" Height="64" CornerRadius="16"
                            Background="#E1F5EE" Margin="0,0,0,12"
                            HorizontalAlignment="Center">
                        <TextBlock Text="🚗" FontSize="30"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Vehicle View" FontSize="15"
                               FontWeight="SemiBold" Foreground="#111827"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="View only" FontSize="12"
                               Foreground="#6B7280" Margin="0,4,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Bookings -->
            <Button x:Name="BtnVehicleMaintaince"
                Style="{StaticResource TileStyle}"
                Margin="8" Click="BtnVehicleMaintaince_Click"
        >
                <StackPanel HorizontalAlignment="Center">
                    <Border Width="64" Height="64" CornerRadius="16"
                Background="#FAECE7" Margin="0,0,0,12"
                HorizontalAlignment="Center">
                        <TextBlock Text="⚙" FontSize="30"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Vehicle Maintenance" FontSize="15"
                   FontWeight="SemiBold" Foreground="#111827"
                   HorizontalAlignment="Center"/>
                    <TextBlock Text="Vehicle Maintenance" FontSize="12"
                   Foreground="#6B7280" Margin="0,4,0,0"
                   HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Vehicle Register -->
            <Button x:Name="BtnVehicleRegister"
        Style="{StaticResource TileStyle}"
        Margin="8" Click="BtnVehicleRegister_Click"
        >
                <StackPanel HorizontalAlignment="Center">
                    <Border Width="64" Height="64" CornerRadius="16"
                Background="#F1EFE8" Margin="0,0,0,12"
                HorizontalAlignment="Center">
                        <TextBlock Text="🚗" FontSize="30"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Vehicle Register" FontSize="15"
                   FontWeight="SemiBold" Foreground="#111827"
                   HorizontalAlignment="Center"/>
                    <TextBlock Text="Vehicle Register" FontSize="12"
                   Foreground="#6B7280" Margin="0,4,0,0"
                   HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>



            <!-- Customers -->
            <Button x:Name="BtnCustomers"
                    Style="{StaticResource TileStyle}"
                    Margin="8" Click="BtnCustomers_Click"
                    >
                <StackPanel HorizontalAlignment="Center">
                    <Border Width="64" Height="64" CornerRadius="16"
                            Background="#FAEEDA" Margin="0,0,0,12"
                            HorizontalAlignment="Center">
                        <TextBlock Text="👥" FontSize="30"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Customers" FontSize="15"
                               FontWeight="SemiBold" Foreground="#111827"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Customer records" FontSize="12"
                               Foreground="#6B7280" Margin="0,4,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            
            <!-- Payments -->
            <Button x:Name="BtnPayments"
                    Style="{StaticResource TileStyle}"
                    Margin="8,8,8,8" Click="BtnPayments_Click"
                    >
                <StackPanel HorizontalAlignment="Center">
                    <Border Width="64" Height="64" CornerRadius="16"
                            Background="#EAF3DE" Margin="0,0,0,12"
                            HorizontalAlignment="Center">
                        <TextBlock Text="💳" FontSize="30"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Payments" FontSize="15"
                               FontWeight="SemiBold" Foreground="#111827"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Invoices and payments" FontSize="12"
                               Foreground="#6B7280" Margin="0,4,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Reports -->
            <Button x:Name="BtnReports"
                    Style="{StaticResource TileStyle}"
                    Margin="8" Click="BtnReports_Click"
                    >
                <StackPanel HorizontalAlignment="Center">
                    <Border Width="64" Height="64" CornerRadius="16"
                            Background="#E6F1FB" Margin="0,0,0,12"
                            HorizontalAlignment="Center">
                        <TextBlock Text="📈" FontSize="30"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Reports" FontSize="15"
                               FontWeight="SemiBold" Foreground="#111827"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Export and analytics" FontSize="12"
                               Foreground="#6B7280" Margin="0,4,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            
        </UniformGrid>

        <!-- ── Footer ── -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#E3EAF3"
                BorderThickness="0,1,0,0"
                Padding="40,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Avatar -->
                <Grid Grid.Column="0" Margin="0,0,12,0">
                    <Ellipse Width="40" Height="40" Fill="#42A5F5"/>
                    <TextBlock x:Name="TxtInitials"
                               Text="JS"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="SemiBold"/>
                </Grid>

                <!-- Name, role, clock -->
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Margin="0,0,0,0">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="Logged in: "
                                   FontSize="14"
                                   Foreground="#6B7280"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtLoggedName"
                                   Text="John Smith"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   VerticalAlignment="Center"/>
                        <Border x:Name="RoleBadge"
                                Background="#EEEDFE"
                                CornerRadius="4"
                                Padding="7,2"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="TxtLoggedRole"
                                       Text="Admin"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#3C3489"/>
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="TxtDateTime"
                               FontSize="12"
                               Foreground="#9CA3AF"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Logout -->
                <Button Grid.Column="2"
                        x:Name="BtnLogout"
                        Content="⏻  Logout"
                        Height="38"
                        Padding="20,0"
                        Background="#C62828"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Cursor="Hand" Click="BtnLogout_Click"
                        >
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#B71C1C"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

    </Grid>
</Window>