<Window x:Class="Drive_Smart_2._0.Views.Payment.payment_details"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Drive_Smart_2._0.Views.Payment"
        mc:Ignorable="d"
        Title="payment_details" Height="700" Width="1200">
    <Grid Margin="0,0,66,-6" RenderTransformOrigin="0.592,0.52">
        <Border Width="220"
            Background="#1565C0"
            HorizontalAlignment="Left" Margin="0,0,0,6">

            <StackPanel Margin="15">

                <TextBlock Text="RENTAL SYSTEM"
                    FontSize="22"
                    FontWeight="Bold"
                    Foreground="White"
                    />

                <Button Content="Dashboard"
                    Height="45"
                    Margin="0,5"
                    Background="#1E88E5"
                    Foreground="White"
                    BorderThickness="0"/>

                <Button Content="Vehicles"
                    Height="45"
                    Margin="0,5"
                    Background="#1565C0"
                    Foreground="White"
                    BorderThickness="0"/>

                <Button Content="Customers"
                    Height="45"
                    Margin="0,5"
                    Background="#1565C0"
                    Foreground="White"
                    BorderThickness="0"/>

                <Button Content="Bookings"
                    Height="45"
                    Margin="0,5"
                    Background="#1565C0"
                    Foreground="White"
                    BorderThickness="0"/>

                <Button Content="Payments"
                    Height="45"
                    Margin="0,5"
                    Background="#1565C0"
                    Foreground="White"
                    BorderThickness="0"/>

                <Button Content="Reports"
                    Height="45"
                    Margin="0,5"
                    Background="#1565C0"
                    Foreground="White"
                    BorderThickness="0"/>
            </StackPanel>

        </Border>
        <TextBlock
            FontSize="28"
            FontWeight="Bold"
            VerticalAlignment="Top" Margin="266,21,74,0" Height="69"><Run Text="Customer Profile Lookup &amp; Payment Portal"/><LineBreak/></TextBlock>
        <TextBox x:Name="CustomerIdTextBox" TextWrapping="Wrap" Margin="266,135,543,519" TextChanged="TextBox_TextChanged"/>
        <TextBlock
            FontWeight="Bold"
            VerticalAlignment="Top" Margin="266,36,74,0" Height="69" FontSize="14"><Run/><LineBreak/><Run Text="Lookup customer details and record a payment transaction."/><LineBreak/><Run/></TextBlock>
        <TextBlock
            FontWeight="Bold"
            VerticalAlignment="Top" Margin="266,105,754,0" Height="25" Text="CUSTERMER ID*" FontSize="14"/>
        <Button x:Name="LOOK_UP1" Content="LOCK UP" Margin="604,135,466,517" RenderTransformOrigin="0.5,0.5" Foreground="#FF01060C" Background="#FF424BD4">
            <Button.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-0.625"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Button.RenderTransform>
        </Button>
        <TextBlock
            FontWeight="Bold"
            VerticalAlignment="Top" Margin="266,176,719,0" Height="25" Text="CUSTERMER NAME" FontSize="14"/>
        <TextBox x:Name="CustomerNameTextBox" TextWrapping="Wrap" Margin="266,201,543,453" TextChanged="TextBox_TextChanged"/>
        <TextBlock
            FontWeight="Bold"
            VerticalAlignment="Top" Margin="266,242,719,0" Height="25" Text="TEL-NUMBER" FontSize="14"/>
        <TextBox x:Name="TelNumberTextBox" TextWrapping="Wrap" Margin="266,267,543,387" TextChanged="TextBox_TextChanged"/>
        <TextBlock
            FontWeight="Bold"
            VerticalAlignment="Top" Margin="266,317,719,0" Height="25" Text="ADRESSS" FontSize="14"/>
        <TextBox x:Name="AddressTextBox" TextWrapping="Wrap" Margin="266,347,543,307" TextChanged="TextBox_TextChanged"/>
        <ComboBox x:Name="PaymentMethodComboBox" Margin="1002,913,76,-244" RenderTransformOrigin="2.741,1.969" SelectedIndex="0" SelectionChanged="ComboBox_SelectionChanged">
            <ComboBox.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-360.61"/>
                    <TranslateTransform X="-543.288" Y="-481.682"/>
                </TransformGroup>
            </ComboBox.RenderTransform>
            <ComboBoxItem Content="HAND CASH"/>
            <ComboBoxItem Content="BANK TRANSFER"/>
        </ComboBox>
        <TextBlock
            FontWeight="Bold"
            VerticalAlignment="Top" Margin="266,432,681,0" Height="21" Text="SELECT PAYMENT METHOD" FontSize="14"/>
        <TextBlock
            FontWeight="Bold"
            VerticalAlignment="Top" Margin="748,140,237,0" Height="25" Text="VEHICLE NUMBER" FontSize="14"/>
        <TextBox x:Name="VehicleNumberTextBox" TextWrapping="Wrap" Margin="748,165,61,489" TextChanged="TextBox_TextChanged"/>
        <TextBlock
            FontWeight="Bold"
            VerticalAlignment="Top" Margin="748,224,237,0" Height="25" Text="VEHICLE MODLE" FontSize="14"/>
        <TextBox x:Name="VehicleModelTextBox" TextWrapping="Wrap" Margin="748,249,61,405" TextChanged="TextBox_TextChanged"/>
        <TextBlock
            FontWeight="Bold"
            VerticalAlignment="Top" Margin="748,304,237,0" Height="26" Text="RENTAL DURATION" FontSize="14"/>
        <TextBox x:Name="RentalDurationTextBox" TextWrapping="Wrap" Margin="748,330,61,324" TextChanged="TextBox_TextChanged"/>
        <TextBlock
            VerticalAlignment="Top" Margin="748,380,237,0" Height="26" Text="TOTALE DUE RENT LKR" FontSize="14" FontFamily="Verdana" FontStyle="Italic" FontWeight="Bold"/>
        <TextBox x:Name="TotalDueTextBox" TextWrapping="Wrap" Margin="748,406,61,248" TextChanged="TextBox_TextChanged"/>
        <Button x:Name="LOOK_UP1_Copy" Content="PROCED TO  PAYMENT" Margin="754,509,79,118" RenderTransformOrigin="0.5,0.5" Foreground="#FF01060C" Background="#FF424BD4" Click="LOOK_UP1_Copy_Click" FontFamily="Verdana" FontSize="20" FontStyle="Italic" FontWeight="Bold">
            <Button.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-0.625"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Button.RenderTransform>
        </Button>
    </Grid>
</Window>
