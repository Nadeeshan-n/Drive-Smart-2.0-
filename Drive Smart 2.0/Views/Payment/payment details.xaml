<Window x:Class="Drive_Smart_2._0.Views.Payment.payment_details"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Drive_Smart_2._0.Views.Payment"
        mc:Ignorable="d"
        Title="Payment Details" Height="700" Width="1200"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Palette -->
        <SolidColorBrush x:Key="BrandPrimary" Color="#1565C0"/>
        <SolidColorBrush x:Key="BrandPrimaryLight" Color="#1E88E5"/>
        <SolidColorBrush x:Key="BrandBorder" Color="#E0E4EA"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1A1D23"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#5F6877"/>

        <!-- Flat button base: removes the default Windows button chrome/bevel -->
        <Style x:Key="FlatButtonBase" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.78"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarNavButton" TargetType="Button" BasedOn="{StaticResource FlatButtonBase}">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="14,0,0,0"/>
        </Style>

        <Style x:Key="SidebarNavButtonActive" TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
            <Setter Property="Background" Value="#1E88E5"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource FlatButtonBase}">
            <Setter Property="Background" Value="{StaticResource BrandPrimary}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource FlatButtonBase}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource BrandPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrandPrimary}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Margin" Value="2,0,0,6"/>
        </Style>

        <Style x:Key="FormTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#D7DCE3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrandBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="2" Opacity="0.07" Color="#1A1D23"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F0F2F5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource BrandPrimary}">
            <StackPanel Margin="20,28,20,20">
                <TextBlock Text="RENTAL SYSTEM" FontSize="20" FontWeight="Bold" Foreground="White" Margin="4,0,0,28"/>
                <Button Content="Dashboard" Style="{StaticResource SidebarNavButton}"/>
                <Button Content="Vehicles" Style="{StaticResource SidebarNavButton}"/>
                <Button Content="Customers" Style="{StaticResource SidebarNavButton}"/>
                <Button Content="Bookings" Style="{StaticResource SidebarNavButton}"/>
                <Button Content="Payments" Style="{StaticResource SidebarNavButtonActive}"/>
                <Button Content="Reports" Style="{StaticResource SidebarNavButton}"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Column="1" Margin="40,32,40,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="Customer Profile &amp; Payment" FontSize="26" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                <TextBlock Text="Look up a customer, confirm the rental, and record the payment." FontSize="13" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="28" VerticalAlignment="Top">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left column: customer -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="CUSTOMER" FontSize="12" FontWeight="Bold" Foreground="{StaticResource BrandPrimary}" Margin="0,0,0,16"/>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Customer ID" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Row="1" Grid.Column="0" x:Name="CustomerIdTextBox"
                                     Style="{StaticResource FormTextBox}" TextChanged="TextBox_TextChanged"/>
                            <Button Grid.Row="1" Grid.Column="2" x:Name="LOOK_UP1" Content="Look up"
                                    Style="{StaticResource SecondaryButton}" Height="38"/>
                        </Grid>

                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Customer Name" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="CustomerNameTextBox" Style="{StaticResource FormTextBox}" TextChanged="TextBox_TextChanged"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Phone Number" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TelNumberTextBox" Style="{StaticResource FormTextBox}" TextChanged="TextBox_TextChanged"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,18">
                            <TextBlock Text="Address" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="AddressTextBox" Style="{StaticResource FormTextBox}"
                                     Height="64" TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalContentAlignment="Top" Padding="10,8"
                                     TextChanged="TextBox_TextChanged"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Payment Method" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="PaymentMethodComboBox" Height="38" SelectedIndex="0"
                                      FontSize="14" VerticalContentAlignment="Center" Padding="10,0"
                                      SelectionChanged="ComboBox_SelectionChanged">
                                <ComboBoxItem Content="Cash"/>
                                <ComboBoxItem Content="Bank Transfer"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>

                    <!-- Right column: vehicle / rental / action -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="VEHICLE &amp; RENTAL" FontSize="12" FontWeight="Bold" Foreground="{StaticResource BrandPrimary}" Margin="0,0,0,16"/>

                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Vehicle Number" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="VehicleNumberTextBox" Style="{StaticResource FormTextBox}" TextChanged="TextBox_TextChanged"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Vehicle Model" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="VehicleModelTextBox" Style="{StaticResource FormTextBox}" TextChanged="TextBox_TextChanged"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Rental Duration" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="RentalDurationTextBox" Style="{StaticResource FormTextBox}" TextChanged="TextBox_TextChanged"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,28">
                            <TextBlock Text="Total Due (LKR)" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TotalDueTextBox" Style="{StaticResource FormTextBox}" FontWeight="Bold" TextChanged="TextBox_TextChanged"/>
                        </StackPanel>

                        <Button x:Name="LOOK_UP1_Copy" Content="Proceed to Payment"
                                Style="{StaticResource PrimaryButton}" Height="46" FontSize="15"
                                Click="LOOK_UP1_Copy_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
