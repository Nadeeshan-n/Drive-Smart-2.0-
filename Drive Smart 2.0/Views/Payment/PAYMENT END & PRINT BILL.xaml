<Window x:Class="Drive_Smart_2._0.Views.Payment.PAYMENT_END___PRINT_BILL"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Drive_Smart_2._0.Views.Payment"
        mc:Ignorable="d"
        Title="PAYMENT_END___PRINT_BILL" Height="700" Width="1200">
    <Grid Width="1200" Height="700">
        <Border Width="220"
            Background="#1565C0"
            HorizontalAlignment="Left" Margin="0,0,0,6">

            <StackPanel Margin="15">

                <TextBlock Text="RENTAL SYSTEM"
                    FontSize="22"
                    FontWeight="Bold"
                    Foreground="White"
                    />

                <Button Content="Dashboard"
                    Height="45"
                    Margin="0,5"
                    Background="#1E88E5"
                    Foreground="White"
                    BorderThickness="0"/>

                <Button Content="Vehicles"
                    Height="45"
                    Margin="0,5"
                    Background="#1565C0"
                    Foreground="White"
                    BorderThickness="0"/>

                <Button Content="Customers"
                    Height="45"
                    Margin="0,5"
                    Background="#1565C0"
                    Foreground="White"
                    BorderThickness="0"/>

                <Button Content="Bookings"
                    Height="45"
                    Margin="0,5"
                    Background="#1565C0"
                    Foreground="White"
                    BorderThickness="0"/>

                <Button Content="Payments"
                    Height="45"
                    Margin="0,5"
                    Background="#1565C0"
                    Foreground="White"
                    BorderThickness="0"/>

                <Button Content="Reports"
                    Height="45"
                    Margin="0,5"
                    Background="#1565C0"
                    Foreground="White"
                    BorderThickness="0"/>
            </StackPanel>

        </Border>

        <Image Source="/Views/Payment/Image1.png" Stretch="Uniform"
               HorizontalAlignment="Center" VerticalAlignment="Top"
               Width="90" Height="90" Margin="0,20,0,0"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                    VerticalAlignment="Top" Margin="0,120,0,0">
            <Border Width="36" Height="36" CornerRadius="18" Background="#2E7D32">
                <TextBlock Text="&#10003;" FontSize="20" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Payment Successful" FontSize="24" FontWeight="Bold"
                       Foreground="#2E7D32" VerticalAlignment="Center" Margin="10,0,0,0"/>
        </StackPanel>

        <Border x:Name="ReceiptCard" Margin="266,185,266,165" Background="#F7F7F7"
                BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6">
            <StackPanel Margin="30">
                <TextBlock Text="RECEIPT" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="Receipt No:" FontWeight="Bold" Width="160"/>
                    <TextBlock x:Name="ReceiptNumberText"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="Date:" FontWeight="Bold" Width="160"/>
                    <TextBlock x:Name="PaymentDateText"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="Customer ID:" FontWeight="Bold" Width="160"/>
                    <TextBlock x:Name="CustomerIdText"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="Customer Name:" FontWeight="Bold" Width="160"/>
                    <TextBlock x:Name="CustomerNameText"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="Vehicle:" FontWeight="Bold" Width="160"/>
                    <TextBlock x:Name="VehicleText"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="Rental Duration:" FontWeight="Bold" Width="160"/>
                    <TextBlock x:Name="RentalDurationText"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="Payment Method:" FontWeight="Bold" Width="160"/>
                    <TextBlock x:Name="PaymentMethodText"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="Total Paid (LKR):" FontWeight="Bold" Width="160"/>
                    <TextBlock x:Name="TotalDueText" FontWeight="Bold" Foreground="#1565C0" FontSize="16"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Button x:Name="PrintInvoiceButton" Content="PRINT INVOICE" Margin="476,560,504,92"
                RenderTransformOrigin="0.5,0.5" Foreground="#FF01060C" Background="#FF424BD4"
                Click="PrintInvoiceButton_Click" FontFamily="Verdana" FontStyle="Italic" FontWeight="Bold">
            <Button.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-0.625"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Button.RenderTransform>
        </Button>
        <Button x:Name="BackToDashboardButton" Content="BACK TO DASHBORD" Margin="720,560,260,92"
                RenderTransformOrigin="0.5,0.5" Foreground="#FF01060C" Background="#FF424BD4"
                Click="BackToDashboardButton_Click" FontFamily="Verdana" FontStyle="Italic" FontWeight="Bold">
            <Button.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-0.625"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Button.RenderTransform>
        </Button>

    </Grid>
</Window>