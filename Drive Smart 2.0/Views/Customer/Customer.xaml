<Window x:Class="Drive_Smart_2._0.Views.Customer.Customer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Drive_Smart_2._0.Views.Customer"
        xmlns:uc="clr-namespace:Drive_Smart_2._0.UserControls"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Customer" Height="700" Width="1200" Background="White">
    <Grid Margin="0,0,0,3">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="93*"/>
            <ColumnDefinition Width="565*"/>
            <ColumnDefinition Width="542*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="546*"/>
            <RowDefinition Height="884*"/>
            <RowDefinition Height="41*"/>
            <RowDefinition Height="1241*"/>
            <RowDefinition Height="399*"/>
        </Grid.RowDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
            Background="#1565C0"
            Margin="0,0,443,0" Grid.ColumnSpan="2" Grid.RowSpan="5" Width="215">

            <Grid Margin="15">

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Menu -->

                <uc:SideBar x:Name="SidebarMenu" Grid.Row="0"/>

                <!-- Logged User Section -->
                <uc:SidebarControl Grid.Row="1" Height="184" Margin="14,0,13,0" VerticalAlignment="Top"/>

            </Grid>

        </Border>
        <!-- Page title -->
        <TextBlock FontSize="28" FontWeight="Bold"
                   VerticalAlignment="Top" Margin="451,10,-244,0"
                   Grid.Column="1" Grid.ColumnSpan="2" Text="Customer Details"/>

        <!-- ── Section header: Personal Details ── -->
        <TextBlock Text="Customer Personal Details." FontSize="16"
                   FontFamily="Arial Black" HorizontalAlignment="Left"
                   Margin="170,75,0,0" VerticalAlignment="Top"
                   Width="290" Grid.Column="1"/>

        <!-- Customer Name label + INPUT -->
        <TextBlock Text="Customer Name :" HorizontalAlignment="Left"
                   Margin="170,1,0,0" Grid.Row="1" VerticalAlignment="Top"
                   Width="120" Grid.Column="1"/>
        <TextBox x:Name="txtCustomerName"
                 HorizontalAlignment="Left" Margin="315,0,0,177"
                 Grid.Row="1" TextWrapping="Wrap" VerticalAlignment="Bottom"
                 Width="120" Grid.Column="1" TextChanged="txtCustomerName_TextChanged"/>

        <!-- Contact Number label + INPUT -->
        <TextBlock Text="Contact Number :" HorizontalAlignment="Left"
                   Margin="170,28,0,0" Grid.Row="1" VerticalAlignment="Top"
                   Width="120" Grid.Column="1"/>
        <TextBox x:Name="phonenumber"
                 HorizontalAlignment="Left" Margin="315,25,0,0"
                 Grid.Row="1" TextWrapping="Wrap" VerticalAlignment="Top"
                 Width="120" Grid.Column="1"/>

        <!-- Address label + INPUT -->
        <TextBlock Text="Address :" HorizontalAlignment="Left"
                   Margin="170,65,0,0" Grid.Row="1" VerticalAlignment="Top"
                   Width="120" Grid.Column="1"/>
        <TextBox x:Name="txtAddress"
                 HorizontalAlignment="Left" Margin="315,65,0,0"
                 Grid.Row="1" TextWrapping="Wrap" VerticalAlignment="Top"
                 Width="120" Grid.Column="1"/>

        <!-- Gender label + CHECKBOXES -->
        <TextBlock Text="Gender :" HorizontalAlignment="Left"
                   Margin="170,98,0,0" Grid.Row="1" VerticalAlignment="Top"
                   Width="120" Grid.Column="1"/>
        <CheckBox x:Name="chkMale"   Content="Male"
                  Grid.Column="1" Margin="315,96,0,0" Grid.Row="1"
                  Height="23" VerticalAlignment="Top"
                  Checked="CheckBox_Checked" Unchecked="CheckBox_Checked"/>
        <CheckBox x:Name="chkFemale" Content="Female"
                  Grid.Column="1" Margin="375,97,0,0" Grid.Row="1"
                  Height="23" VerticalAlignment="Top"
                  Checked="CheckBox_Checked" Unchecked="CheckBox_Checked"/>

        <!-- Email label + INPUT -->
        <TextBlock Text="Email Address :" HorizontalAlignment="Left"
                   Margin="170,135,0,0" Grid.Row="1" VerticalAlignment="Top"
                   Width="120" Grid.Column="1"/>
        <TextBox x:Name="txtEmail"
                 HorizontalAlignment="Left" Margin="315,135,0,0"
                 Grid.Row="1" TextWrapping="Wrap" VerticalAlignment="Top"
                 Width="120" Grid.Column="1"/>

        <!-- ── Section header: Identity Details ── -->
        <TextBlock Text="Identity Details." FontSize="16"
                   FontFamily="Arial Black" Grid.Column="1"
                   Margin="170,187,161,0" Grid.Row="1" Grid.RowSpan="2"/>

        <!-- NIC Number label + INPUT -->
        <TextBlock Text="NIC Number :" HorizontalAlignment="Left"
                   Margin="170,32,0,0" Grid.Row="3" VerticalAlignment="Top"
                   Width="120" Grid.Column="1"/>
        <TextBox x:Name="identity"
                 HorizontalAlignment="Left" Margin="315,32,0,0"
                 Grid.Row="3" TextWrapping="Wrap" VerticalAlignment="Top"
                 Width="120" Grid.Column="1"/>

        <!-- Driving License label + INPUT -->
        <TextBlock Text="Driving License Number :" HorizontalAlignment="Left"
                   Margin="170,66,0,0" Grid.Row="3" VerticalAlignment="Top"
                   Width="150" Grid.Column="1"/>
        <TextBox x:Name="txtLicense"
                 HorizontalAlignment="Left" Margin="315,68,0,0"
                 Grid.Row="3" TextWrapping="Wrap" VerticalAlignment="Top"
                 Width="120" Grid.Column="1"/>

        <!-- Submit -->
        <Button Content="Submit" Grid.Column="2" Margin="274,220,175,10"
                Grid.Row="3" Click="Button_Click" FontSize="16"/>
        <Button x:Name="BtnView" Content="View Cusomers" Grid.Column="2" Margin="44,220,320,10"
            Grid.Row="3"  FontSize="16" Click="BtnView_Click"/>
    </Grid>
</Window>