<Window x:Class="Drive_Smart_2._0.Views.Customer.Customer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Drive_Smart_2._0.Views.Customer"
        mc:Ignorable="d"
        Title="Customer" Height="700" Width="1200" Background="White">
    <Grid Margin="0,0,0,-6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="93*"/>
            <ColumnDefinition Width="565*"/>
            <ColumnDefinition Width="542*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="546*"/>
            <RowDefinition Height="884*"/>
            <RowDefinition Height="41*"/>
            <RowDefinition Height="1241*"/>
            <RowDefinition Height="399*"/>
        </Grid.RowDefinitions>
        <Border Width="220"
            Background="#1565C0"
            HorizontalAlignment="Left" Margin="0,0,0,6" Grid.RowSpan="5" Grid.ColumnSpan="2">

            <StackPanel Margin="15">

                <TextBlock Text="RENTAL SYSTEM"
                    FontSize="22"
                    FontWeight="Bold"
                    Foreground="White"
                    Margin="0,20,0,30"/>

                <Button Content="Dashboard"
                    Height="45"
                    Margin="0,5"
                    Background="#1E88E5"
                    Foreground="White"
                    BorderThickness="0"/>

                <Button Content="Vehicles"
                    Height="45"
                    Margin="0,5"
                    Background="#1565C0"
                    Foreground="White"
                    BorderThickness="0"/>

                <Button Content="Customers"
                    Height="45"
                    Margin="0,5"
                    Background="#1565C0"
                    Foreground="White"
                    BorderThickness="0"/>

                <Button Content="Bookings"
                    Height="45"
                    Margin="0,5"
                    Background="#1565C0"
                    Foreground="White"
                    BorderThickness="0"/>

                <Button Content="Payments"
                    Height="45"
                    Margin="0,5"
                    Background="#1565C0"
                    Foreground="White"
                    BorderThickness="0"/>

                <Button Content="Reports"
                    Height="45"
                    Margin="0,5"
                    Background="#1565C0"
                    Foreground="White"
                    BorderThickness="0"/>
            </StackPanel>

        </Border>
        <TextBlock
            FontSize="28"
            FontWeight="Bold"
            VerticalAlignment="Top" Margin="451,10,-244,0" Grid.Column="1" Grid.ColumnSpan="2"><Run Text="Custermer Detail"/><Run Language="en-gb" Text="s"/><Run Text="."/></TextBlock>
        <TextBox HorizontalAlignment="Left" Height="20" Margin="310,121,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" Grid.RowSpan="2" Grid.Column="1"/>
        <TextBox HorizontalAlignment="Left" Margin="170,1,0,0" Grid.Row="1" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" Grid.Column="1" TextChanged="TextBox_TextChanged_2" Text="Custermer Name :"/>
        <TextBox TextWrapping="Wrap" Text="Contact Number :" Margin="173,28,288,0" Grid.Row="1" RenderTransformOrigin="0.5,0.5" Height="23" VerticalAlignment="Top" Grid.Column="1" TextChanged="TextBox_TextChanged_8">
            <TextBox.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-0.2"/>
                    <TranslateTransform/>
                </TransformGroup>
            </TextBox.RenderTransform>
        </TextBox>
        <TextBox x:Name="phonenumber" TextWrapping="Wrap" Width="120" Margin="315,25,130,151" Grid.Row="1" Grid.Column="1" TextChanged="TextBox_TextChanged_10"/>
        <TextBox HorizontalAlignment="Left" Height="0" Margin="490,121,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="122" Grid.Column="1" Grid.ColumnSpan="2"/>
        <TextBox x:Name="identity" HorizontalAlignment="Left" Margin="315,32,0,0" Grid.Row="3" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" Grid.Column="1" TextChanged="TextBox_TextChanged_11"/>
        <TextBox HorizontalAlignment="Left" Margin="170,65,0,0" Grid.Row="1" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" Text="Address :" Grid.Column="1"/>
        <TextBox HorizontalAlignment="Left" Margin="315,65,0,0" Grid.Row="1" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" RenderTransformOrigin="0.173,0.628" Grid.Column="1" TextChanged="TextBox_TextChanged_3"/>
        <TextBox HorizontalAlignment="Left" Margin="170,98,0,0" Grid.Row="1" TextWrapping="Wrap" Text="Gender :" VerticalAlignment="Top" Width="120" TextChanged="TextBox_TextChanged" Grid.Column="1"/>
        <TextBox HorizontalAlignment="Left" Margin="170,135,0,0" Grid.Row="1" TextWrapping="Wrap" Text="Email Address :" VerticalAlignment="Top" Width="120" Grid.Column="1"/>
        <TextBox HorizontalAlignment="Left" Margin="170,75,0,0" TextWrapping="Wrap" Text="Custermer Personal Details." VerticalAlignment="Top" Width="290" TextChanged="TextBox_TextChanged_1" FontSize="16" FontFamily="Arial Black" Grid.Column="1"/>
        <TextBox HorizontalAlignment="Left" Margin="310,135,0,0" Grid.Row="1" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" Grid.Column="1"/>
        <TextBox HorizontalAlignment="Left" Margin="170,32,0,0" Grid.Row="3" TextWrapping="Wrap" Text="NIC Number :" VerticalAlignment="Top" Width="120" Grid.Column="1"/>
        <TextBox TextWrapping="Wrap" Text="Identity Details." Grid.Column="1" Margin="170,187,161,0" Grid.Row="1" Grid.RowSpan="2" TextChanged="TextBox_TextChanged_4" FontFamily="Arial Black" FontSize="16"/>
        <TextBox TextWrapping="Wrap" Text="Driving License : Number" Grid.Column="1" Margin="170,66,266,188" Grid.Row="3" TextChanged="TextBox_TextChanged_5" RenderTransformOrigin="0.453,-0.557"/>
        <TextBox Grid.Column="1" HorizontalAlignment="Left" Margin="315,68,0,0" Grid.Row="3" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" TextChanged="TextBox_TextChanged_9"/>
        <Button Content="Submit" Grid.Column="2" Margin="274,220,175,10" Grid.Row="3" Click="Button_Click" FontSize="16"/>
        <CheckBox Content="Female" Margin="375,97,97,78" Grid.Column="1" Grid.Row="1"/>
        <CheckBox Content="Male" Grid.Column="1" Margin="315,96,157,0" Grid.Row="1" Height="23" VerticalAlignment="Top" Checked="CheckBox_Checked"/>

    </Grid>
</Window>
