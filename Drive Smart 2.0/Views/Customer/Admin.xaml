<Window x:Class="Drive_Smart_2._0.Views.Customer.Admin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Drive_Smart_2._0.Views.Customer"
        mc:Ignorable="d"
        Title="Admin - Customer Records" Height="600" Width="1100"
        Background="White" Loaded="Window_Loaded">

    <Grid>
        <!-- ── Sidebar ── -->
        <Border Width="220" Background="#1565C0" HorizontalAlignment="Left">
            <StackPanel Margin="15">
                <TextBlock Text="RENTAL SYSTEM" FontSize="22" FontWeight="Bold"
                           Foreground="White" Margin="0,20,0,30"/>
                <Button Content="Add New Custermer" Height="45" Margin="0,5"
                        Background="#1E88E5" Foreground="White" BorderThickness="0" Click="Button_Click"/>
                <Button Content="View"  Height="45" Margin="0,5"
                        Background="#1565C0" Foreground="White" BorderThickness="0"/>
                <Button Content=" Update Customers" Height="45" Margin="0,5"
                        Background="#1565C0" Foreground="White" BorderThickness="0"/>
                <Button Content="Delete Account"  Height="45" Margin="0,5"
                        Background="#1565C0" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <!-- ── Main content area ── -->
        <Grid Margin="230,0,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Text="Customer Records"
                       FontSize="26" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="0,0,0,0"
                       Grid.Row="0"/>

            <!-- Toolbar: Search + Refresh + Delete -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                        Grid.Row="1" Margin="0,0,0,5">

                <TextBox x:Name="txtSearch"
                         Width="220" Height="30" Margin="0,0,10,0"
                         VerticalContentAlignment="Center"
                         TextChanged="txtSearch_TextChanged"
                         ToolTip="Search by name, phone or NIC"/>

                <Button Content="🔍 Search" Width="90" Height="30" Margin="0,0,10,0"
                        Background="#1E88E5" Foreground="White" BorderThickness="0"
                        Click="btnSearch_Click"/>

                <Button Content="↺ Refresh" Width="90" Height="30" Margin="0,0,10,0"
                        Background="#43A047" Foreground="White" BorderThickness="0"
                        Click="btnRefresh_Click"/>

                <Button Content="🗑 Delete" Width="90" Height="30"
                        Background="#E53935" Foreground="White" BorderThickness="0"
                        Click="btnDelete_Click"/>
            </StackPanel>

            <!-- DataGrid -->
            <DataGrid x:Name="dgCustomers"
                      Grid.Row="2"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      AlternatingRowBackground="#F5F5F5"
                      RowBackground="White"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      BorderBrush="#BDBDBD" BorderThickness="1"
                      CanUserResizeColumns="True"
                      SelectionChanged="DataGrid_SelectionChanged">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"  Value="#1565C0"/>
                        <Setter Property="Foreground"  Value="White"/>
                        <Setter Property="FontWeight"  Value="Bold"/>
                        <Setter Property="Height"      Value="36"/>
                        <Setter Property="Padding"     Value="8,0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"              Binding="{Binding CustomerID}"     Width="50"/>
                    <DataGridTextColumn Header="Customer Name"   Binding="{Binding CustomerName}"   Width="150"/>
                    <DataGridTextColumn Header="Contact Number"  Binding="{Binding ContactNumber}"  Width="120"/>
                    <DataGridTextColumn Header="Address"         Binding="{Binding Address}"        Width="160"/>
                    <DataGridTextColumn Header="Gender"          Binding="{Binding Gender}"         Width="70"/>
                    <DataGridTextColumn Header="Email Address"   Binding="{Binding EmailAddress}"   Width="170"/>
                    <DataGridTextColumn Header="NIC Number"      Binding="{Binding NICNumber}"      Width="120"/>
                    <DataGridTextColumn Header="Driving License" Binding="{Binding DrivingLicense}" Width="120"/>
                    <DataGridTextColumn Header="Created At"      Binding="{Binding CreatedAt}"      Width="140"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Status bar -->
            <TextBlock x:Name="txtStatus"
                       Grid.Row="3"
                       VerticalAlignment="Center"
                       FontSize="13" Foreground="#555"/>
        </Grid>
    </Grid>
</Window>
