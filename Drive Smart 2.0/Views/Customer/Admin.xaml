<Window x:Class="Drive_Smart_2._0.Views.Customer.Admin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Customer Admin" Height="650" Width="1100"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Grid x:Name="MainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="0"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Customer List -->
        <Grid Grid.Column="0" Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBox x:Name="txtSearch"
                         Width="220" Height="30"
                         VerticalContentAlignment="Center"
                         Padding="6,0"
                         TextChanged="txtSearch_TextChanged"
                         ToolTip="Search by name, phone, NIC or email"/>
                <Button Content="Search"
                        Width="75" Height="30"
                        Margin="6,0,0,0"
                        Click="btnSearch_Click"/>
                <Button Content="Refresh"
                        Width="75" Height="30"
                        Margin="6,0,0,0"
                        Click="btnRefresh_Click"/>
                <Button Content="Delete"
                        Width="75" Height="30"
                        Margin="6,0,0,0"
                        Click="btnDelete_Click"/>
                <Button x:Name="btnAdd"
                        Content="+ Add"
                        Width="80" Height="30"
                        Margin="6,0,0,0"
                        Click="btnAdd_Click"/>
            </StackPanel>

            <!-- DataGrid -->
            <DataGrid x:Name="dgCustomers"
                      Grid.Row="1"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionChanged="DataGrid_SelectionChanged"
                      CanUserResizeRows="False"
                      AlternatingRowBackground="#F5F5F5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"      Binding="{Binding CustomerID}"     Width="50"/>
                    <DataGridTextColumn Header="Name"    Binding="{Binding CustomerName}"   Width="160"/>
                    <DataGridTextColumn Header="Contact" Binding="{Binding ContactNumber}"  Width="120"/>
                    <DataGridTextColumn Header="Email"   Binding="{Binding EmailAddress}"   Width="180"/>
                    <DataGridTextColumn Header="NIC"     Binding="{Binding NICNumber}"      Width="120"/>
                    <DataGridTextColumn Header="Gender"  Binding="{Binding Gender}"         Width="70"/>
                    <DataGridTextColumn Header="License" Binding="{Binding DrivingLicense}" Width="120"/>
                    <DataGridTextColumn Header="Address" Binding="{Binding Address}"        Width="180"/>
                    <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt}"      Width="140"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Status bar -->
            <TextBlock x:Name="txtStatus"
                       Grid.Row="2"
                       Margin="0,6,0,0"
                       FontSize="12"
                       Foreground="Gray"/>
        </Grid>

        <!-- RIGHT: Add Customer Panel -->
        <Border x:Name="AddPanel"
                Grid.Column="1"
                Visibility="Collapsed"
                Background="#FAFAFA"
                BorderBrush="#CCCCCC"
                BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                <StackPanel>
                    <TextBlock Text="Add Customer"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="Full Name *"/>
                    <TextBox x:Name="txtNewName"
                             Height="30" Margin="0,2,0,10"
                             VerticalContentAlignment="Center"
                             Padding="6,0"/>

                    <TextBlock Text="Contact Number *"/>
                    <TextBox x:Name="txtNewContact"
                             Height="30" Margin="0,2,0,10"
                             VerticalContentAlignment="Center"
                             Padding="6,0"/>

                    <TextBlock Text="Email Address"/>
                    <TextBox x:Name="txtNewEmail"
                             Height="30" Margin="0,2,0,10"
                             VerticalContentAlignment="Center"
                             Padding="6,0"/>

                    <TextBlock Text="NIC Number *"/>
                    <TextBox x:Name="txtNewNIC"
                             Height="30" Margin="0,2,0,10"
                             VerticalContentAlignment="Center"
                             Padding="6,0"/>

                    <TextBlock Text="Driving License"/>
                    <TextBox x:Name="txtNewLicense"
                             Height="30" Margin="0,2,0,10"
                             VerticalContentAlignment="Center"
                             Padding="6,0"/>

                    <TextBlock Text="Gender"/>
                    <ComboBox x:Name="cmbGender"
                              Height="30"
                              Margin="0,2,0,10">
                        <ComboBoxItem Content="Male"/>
                        <ComboBoxItem Content="Female"/>
                        <ComboBoxItem Content="Other"/>
                    </ComboBox>

                    <TextBlock Text="Address"/>
                    <TextBox x:Name="txtNewAddress"
                             Height="60" Margin="0,2,0,10"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Padding="6,4"/>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Save"
                                Width="90" Height="32"
                                Click="btnSaveCustomer_Click"/>
                        <Button Content="Cancel"
                                Width="90" Height="32"
                                Margin="10,0,0,0"
                                Click="btnCancelAdd_Click"/>
                    </StackPanel>

                    <TextBlock x:Name="txtPanelError"
                               Foreground="Red"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0"
                               FontSize="12"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

    </Grid>
</Window>