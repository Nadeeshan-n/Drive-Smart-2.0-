<Window x:Class="Drive_Smart_2._0.models.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vehicle Rental Dashboard"
        Height="700" Width="1200"
        Background="#F5F9FF">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="97*"/>
            <ColumnDefinition Width="303*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Width="220"
                Background="#1565C0"
                HorizontalAlignment="Left">

            <StackPanel Margin="15">

                <TextBlock Text="RENTAL SYSTEM"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,20,0,30"/>

                <Button Content="Dashboard"
                        Height="45"
                        Margin="0,5"
                        Background="#1E88E5"
                        Foreground="White"
                        BorderThickness="0"/>

                <Button Content="Vehicles"
                        Height="45"
                        Margin="0,5"
                        Background="#1565C0"
                        Foreground="White"
                        BorderThickness="0" Click="Button_Click"/>

                <Button Content="Customers"
                        Height="45"
                        Margin="0,5"
                        Background="#1565C0"
                        Foreground="White"
                        BorderThickness="0"/>

                <Button Content="Bookings"
                        Height="45"
                        Margin="0,5"
                        Background="#1565C0"
                        Foreground="White"
                        BorderThickness="0"/>

                <Button Content="Payments"
                        Height="45"
                        Margin="0,5"
                        Background="#1565C0"
                        Foreground="White"
                        BorderThickness="0"/>

                <Button Content="Reports"
                        Height="45"
                        Margin="0,5"
                        Background="#1565C0"
                        Foreground="White"
                        BorderThickness="0"/>
            </StackPanel>

        </Border>

        <!-- Main Content -->
        <Grid Margin="240,20,20,20" Grid.ColumnSpan="2">

            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="150"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="White"
                    CornerRadius="10">

                <Grid Margin="20,0">
                    <TextBlock Text="Dashboard"
                               FontSize="28"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>

                    <TextBlock Text="Welcome Admin"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="16"
                               Foreground="Gray"/>
                </Grid>

            </Border>

            <!-- Statistics Cards -->
            <Grid Grid.Row="1" Margin="0,20,0,20">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="5"
                        Background="#2196F3"
                        CornerRadius="12">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="totvehecles" Text="150"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Total Vehicles"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Margin="5"
                        Background="#2196F3"
                        CornerRadius="12">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="availablevehecletxt" Text="95"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Available"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Margin="5"
                        Background="#2196F3"
                        CornerRadius="12">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="rentedvehecletxt" Text="45"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Currently Rented"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3"
                        Margin="5"
                        Background="#2196F3"
                        CornerRadius="12">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="monthlyincometxt" Text="Rs. 250K"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Monthly Revenue"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </Grid>

            <!-- Recent Rentals Table -->
            <Border Grid.Row="2"
                    Background="White"
                    CornerRadius="12"
                    Padding="15">

                <StackPanel>

                    <TextBlock Text="Recent Rentals"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <DataGrid AutoGenerateColumns="False"
                              Height="300">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Rental ID"
                                                Binding="{Binding RentalID}"/>

                            <DataGridTextColumn Header="Customer"
                                                Binding="{Binding CustomerName}"/>

                            <DataGridTextColumn Header="Vehicle"
                                                Binding="{Binding VehicleName}"/>

                            <DataGridTextColumn Header="Start Date"
                                                Binding="{Binding StartDate}"/>

                            <DataGridTextColumn Header="Return Date"
                                                Binding="{Binding ReturnDate}"/>

                            <DataGridTextColumn Header="Status"
                                                Binding="{Binding Status}"/>
                        </DataGrid.Columns>

                    </DataGrid>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>
</Window>