<Page x:Class="Drive_Smart_2._0.Views.VehicleView.MaintenanceView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Maintenance Management"
      Background="#F5F9FF">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ SIDEBAR (identical to AdminVehicleView) ═══ -->
        <Border Background="#1565C0" Grid.Column="0">
            <StackPanel Margin="15">
                <TextBlock Text="RENTAL SYSTEM" FontSize="22" FontWeight="Bold"
                           Foreground="White" Margin="0,20,0,30"/>

                <Button Content="Vehicle Manager" Height="45" Margin="0,5"
                        Background="#1565C0" Foreground="White"
                        BorderThickness="0" Click="Button_Click_1"/>

                <Grid Margin="0,5">
                    <Button Content="Maintenance Manager" Height="45"
                            Background="#1E88E5" Foreground="White"
                            BorderThickness="0"/>
                    <Border x:Name="badgeBorder"
                            Background="Red" CornerRadius="10"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            MinWidth="20" Height="20" Margin="0,2,4,0"
                            Visibility="Collapsed" Padding="4,0">
                        <TextBlock x:Name="badgeCount"
                                   Text="0" Foreground="White"
                                   FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <Button Content="View Catalogs" Height="45" Margin="0,5"
                        Background="#1565C0" Foreground="White"
                        BorderThickness="0" Click="Button_Click_3"/>

                <Button Content="Dashboard" Height="45" Margin="0,5"
                        Background="#1565C0" Foreground="White"
                        BorderThickness="0" Click="Button_Click"/>

                <Button Content="Exit" Height="45" Margin="0,5"
                        Background="#1565C0" Foreground="White"
                        BorderThickness="0" Click="Button_Click_2"/>
            </StackPanel>
        </Border>

        <!-- ═══ MAIN CONTENT ═══ -->
        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Background="White" CornerRadius="10" Grid.Row="0" Padding="15,0">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Maintenance Management"
                               FontSize="26" FontWeight="Bold"
                               VerticalAlignment="Center" Grid.Column="0"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="txtOverdueCount"
                                   FontSize="13" Foreground="#E53935"
                                   FontWeight="SemiBold" VerticalAlignment="Center"
                                   Margin="0,0,16,0"/>
                        <TextBlock x:Name="txtDueSoonCount"
                                   FontSize="13" Foreground="#FB8C00"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Form Panel -->
            <Border Background="White" CornerRadius="10" Grid.Row="1"
                    Margin="0,10,0,0" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Labels -->
                    <TextBlock Text="Vehicle"          Grid.Column="0" Grid.Row="0" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="Maintenance Type" Grid.Column="1" Grid.Row="0" FontWeight="SemiBold" Margin="8,0,0,4"/>
                    <TextBlock Text="Custom Type"      Grid.Column="2" Grid.Row="0" FontWeight="SemiBold" Margin="8,0,0,4"/>
                    <TextBlock Text="Status"           Grid.Column="3" Grid.Row="0" FontWeight="SemiBold" Margin="8,0,0,4"/>
                    <TextBlock Text="Scheduled Date"   Grid.Column="4" Grid.Row="0" FontWeight="SemiBold" Margin="8,0,0,4"/>
                    <TextBlock Text="Completed Date"   Grid.Column="5" Grid.Row="0" FontWeight="SemiBold" Margin="8,0,0,4"/>

                    <!-- Row 1: Inputs -->
                    <ComboBox x:Name="cmbVehicle" Grid.Column="0" Grid.Row="1"
                              Height="34" Margin="0,0,6,0"
                              SelectionChanged="cmbVehicle_SelectionChanged"/>

                    <ComboBox x:Name="cmbType" Grid.Column="1" Grid.Row="1"
                              Height="34" Margin="0,0,6,0"
                              SelectionChanged="cmbType_SelectionChanged">
                        <ComboBoxItem Content="Oil Change"        IsSelected="True"/>
                        <ComboBoxItem Content="Tire Rotation"/>
                        <ComboBoxItem Content="Brake Inspection"/>
                        <ComboBoxItem Content="Battery Check"/>
                        <ComboBoxItem Content="Engine Service"/>
                        <ComboBoxItem Content="AC Service"/>
                        <ComboBoxItem Content="Full Service"/>
                        <ComboBoxItem Content="Other Repairs"/>
                        <ComboBoxItem Content="Custom"/>
                    </ComboBox>

                    <TextBox x:Name="txtCustomType" Grid.Column="2" Grid.Row="1"
                             Height="34" Padding="6" Margin="0,0,6,0"
                             IsEnabled="False" Background="#F5F5F5"
                             ToolTip="Only for Custom type"/>

                    <ComboBox x:Name="cmbStatus" Grid.Column="3" Grid.Row="1"
                              Height="34" Margin="0,0,6,0">
                        <ComboBoxItem Content="Scheduled"   IsSelected="True"/>
                        <ComboBoxItem Content="In Progress"/>
                        <ComboBoxItem Content="Completed"/>
                        <ComboBoxItem Content="Cancelled"/>
                    </ComboBox>

                    <DatePicker x:Name="dpScheduled" Grid.Column="4" Grid.Row="1"
                                Height="34" Margin="0,0,6,0"/>
                    <DatePicker x:Name="dpCompleted" Grid.Column="5" Grid.Row="1"
                                Height="34"/>

                    <!-- Row 3: Labels -->
                    <TextBlock Text="Current Mileage (km)"  Grid.Column="0" Grid.Row="3" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="Interval Days"          Grid.Column="1" Grid.Row="3" FontWeight="SemiBold" Margin="8,0,0,4"/>
                    <TextBlock Text="Interval Mileage (km)"  Grid.Column="2" Grid.Row="3" FontWeight="SemiBold" Margin="8,0,0,4"/>
                    <TextBlock Text="Cost (LKR)"             Grid.Column="3" Grid.Row="3" FontWeight="SemiBold" Margin="8,0,0,4"/>
                    <TextBlock Text="Notes"                  Grid.Column="4" Grid.Row="3" FontWeight="SemiBold" Margin="8,0,0,4" Grid.ColumnSpan="2"/>

                    <!-- Row 4: Inputs -->
                    <TextBox x:Name="txtMileage"         Grid.Column="0" Grid.Row="4" Height="34" Padding="6" Margin="0,0,6,0"/>
                    <TextBox x:Name="txtIntervalDays"    Grid.Column="1" Grid.Row="4" Height="34" Padding="6" Margin="0,0,6,0" Text="90"/>
                    <TextBox x:Name="txtIntervalMileage" Grid.Column="2" Grid.Row="4" Height="34" Padding="6" Margin="0,0,6,0" Text="5000"/>
                    <TextBox x:Name="txtCost"            Grid.Column="3" Grid.Row="4" Height="34" Padding="6" Margin="0,0,6,0"/>
                    <TextBox x:Name="txtNotes"           Grid.Column="4" Grid.Row="4" Height="34" Padding="6" Grid.ColumnSpan="2"/>

                    <!-- Row 6: Buttons + Filter -->
                    <StackPanel Grid.Column="0" Grid.ColumnSpan="6" Grid.Row="6"
                                Orientation="Horizontal" Margin="0,4,0,0">
                        <Button x:Name="btnSave"     Content="💾 Save"       Width="110" Height="36" Margin="0,0,8,0" Background="#1E88E5" Foreground="White" BorderThickness="0" Click="btnSave_Click"/>
                        <Button x:Name="btnComplete" Content="✅ Mark Done"  Width="120" Height="36" Margin="0,0,8,0" Background="#43A047" Foreground="White" BorderThickness="0" Click="btnComplete_Click"/>
                        <Button x:Name="btnDelete"   Content="🗑️ Delete"     Width="100" Height="36" Margin="0,0,8,0" Background="#E53935" Foreground="White" BorderThickness="0" Click="btnDelete_Click"/>
                        <Button x:Name="btnClear"    Content="✖ Clear"       Width="80"  Height="36" Margin="0,0,8,0" Background="#9E9E9E" Foreground="White" BorderThickness="0" Click="btnClear_Click"/>
                        <Button x:Name="btnAuditLog" Content="📋 Audit Log"  Width="120" Height="36" Margin="0,0,8,0" Background="#6A1B9A" Foreground="White" BorderThickness="0" Click="btnAuditLog_Click"/>
                        <Border Width="1" Background="#DDDDDD" Margin="8,4,16,4"/>
                        <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cmbFilter" Width="140" Height="36"
                                  SelectionChanged="cmbFilter_SelectionChanged">
                            <ComboBoxItem Content="All Records"  IsSelected="True"/>
                            <ComboBoxItem Content="Overdue"/>
                            <ComboBoxItem Content="Due Soon"/>
                            <ComboBoxItem Content="Scheduled"/>
                            <ComboBoxItem Content="In Progress"/>
                            <ComboBoxItem Content="Completed"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Stats Bar -->
            <Grid Grid.Row="2" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#FFEBEE" CornerRadius="8"
                        Padding="14,10" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="OVERDUE" FontSize="11"
                                   Foreground="#E53935" FontWeight="Bold"/>
                        <TextBlock x:Name="statOverdue" Text="0" FontSize="24"
                                   FontWeight="Bold" Foreground="#E53935"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#FFF3E0" CornerRadius="8"
                        Padding="14,10" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="DUE WITHIN 7 DAYS" FontSize="11"
                                   Foreground="#FB8C00" FontWeight="Bold"/>
                        <TextBlock x:Name="statDueSoon" Text="0" FontSize="24"
                                   FontWeight="Bold" Foreground="#FB8C00"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#E8F5E9" CornerRadius="8"
                        Padding="14,10" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="COMPLETED" FontSize="11"
                                   Foreground="#43A047" FontWeight="Bold"/>
                        <TextBlock x:Name="statCompleted" Text="0" FontSize="24"
                                   FontWeight="Bold" Foreground="#43A047"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="#E3F2FD" CornerRadius="8"
                        Padding="14,10">
                    <StackPanel>
                        <TextBlock Text="TOTAL RECORDS" FontSize="11"
                                   Foreground="#1565C0" FontWeight="Bold"/>
                        <TextBlock x:Name="statTotal" Text="0" FontSize="24"
                                   FontWeight="Bold" Foreground="#1565C0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- DataGrid -->
            <Border Background="White" CornerRadius="10" Grid.Row="3"
                    Padding="10" Margin="0,10,0,0">
                <DataGrid x:Name="dgMaintenance"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          Background="White"
                          RowBackground="White"
                          AlternatingRowBackground="#F0F4FF"
                          SelectionChanged="dgMaintenance_SelectionChanged">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusColor}" Value="Red">
                                    <Setter Property="Background" Value="#FFEBEE"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusColor}" Value="Orange">
                                    <Setter Property="Background" Value="#FFF8E1"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"        Binding="{Binding Id}"             Width="40"/>
                        <DataGridTextColumn Header="Vehicle"   Binding="{Binding VehicleName}"    Width="*"/>
                        <DataGridTextColumn Header="Plate"     Binding="{Binding VehiclePlate}"   Width="90"/>
                        <DataGridTextColumn Header="Type"      Binding="{Binding DisplayType}"    Width="*"/>
                        <DataGridTextColumn Header="Status"    Binding="{Binding Status}"         Width="90"/>
                        <DataGridTextColumn Header="Scheduled" Binding="{Binding ScheduledDate}"  Width="95"/>
                        <DataGridTextColumn Header="Completed" Binding="{Binding CompletedDate}"  Width="95"/>
                        <DataGridTextColumn Header="Mileage"   Binding="{Binding CurrentMileage}" Width="80"/>
                        <DataGridTextColumn Header="Next (km)" Binding="{Binding NextMileage}"    Width="80"/>
                        <DataGridTextColumn Header="Next Due"  Binding="{Binding NextDueDate}"    Width="95"/>
                        <DataGridTextColumn Header="Days Left" Binding="{Binding DaysLeft}"       Width="80"/>
                        <DataGridTextColumn Header="Cost"      Binding="{Binding CostDisplay}"    Width="*"/>
                        <DataGridTextColumn Header="Updated"   Binding="{Binding UpdatedAt}"      Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <Frame x:Name="MaintenanceViewFrame"
               Grid.Column="0" Grid.ColumnSpan="2"
               NavigationUIVisibility="Hidden"
               Visibility="Collapsed"/>
    </Grid>
</Page>