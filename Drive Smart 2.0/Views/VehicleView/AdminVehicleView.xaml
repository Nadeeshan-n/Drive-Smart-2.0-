<Page x:Class="Drive_Smart_2._0.Views.VehicleView.AdminVehicleView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin - Vehicle Management"
        Height="700" Width="1200"
        Background="#F5F9FF">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Background="#1565C0" Grid.Column="0">
            <StackPanel Margin="15">
                <TextBlock Text="RENTAL SYSTEM" FontSize="22" FontWeight="Bold"
                           Foreground="White" Margin="0,20,0,30"/>
                <Button Content="Catalog"   Height="45" Margin="0,5" Background="#1565C0" Foreground="White" BorderThickness="0" Click="Button_Click_1"/>
                <Button Content="Vehicles"  Height="45" Margin="0,5" Background="#1E88E5" Foreground="White" BorderThickness="0"/>
                <Button Content="Customers" Height="45" Margin="0,5" Background="#1565C0" Foreground="White" BorderThickness="0"/>
                <Button Content="Bookings"  Height="45" Margin="0,5" Background="#1565C0" Foreground="White" BorderThickness="0"/>
                <Button Content="Payments"  Height="45" Margin="0,5" Background="#1565C0" Foreground="White" BorderThickness="0"/>
                <Button Content="Reports"   Height="45" Margin="0,5" Background="#1565C0" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Background="White" CornerRadius="10" Grid.Row="0">
                <TextBlock Text="Vehicle Management" FontSize="26" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="20,0"/>
            </Border>

            <!-- Form Panel -->
            <Border Background="White" CornerRadius="10" Grid.Row="1" Margin="0,10,0,10" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Image Preview -->
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <Border Width="140" Height="110" BorderBrush="#CCCCCC"
                                BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                            <Image x:Name="imgPreview" Stretch="UniformToFill"/>
                        </Border>
                        <Button x:Name="btnPickImage" Content="📷 Choose Image"
                                Height="32" Margin="0,8,0,0"
                                Background="#1565C0" Foreground="White"
                                BorderThickness="0" Click="btnPickImage_Click"/>
                        <TextBlock x:Name="txtImageName" Text="No image selected"
                                   FontSize="10" Foreground="Gray"
                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Fields -->
                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Brand"      Grid.Column="0" Grid.Row="0" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock Text="Model"      Grid.Column="1" Grid.Row="0" FontWeight="SemiBold" Margin="8,0,0,4"/>
                        <TextBlock Text="Plate No."  Grid.Column="2" Grid.Row="0" FontWeight="SemiBold" Margin="8,0,0,4"/>
                        <TextBlock Text="Year"       Grid.Column="3" Grid.Row="0" FontWeight="SemiBold" Margin="8,0,0,4"/>
                        <TextBlock Text="Color"      Grid.Column="4" Grid.Row="0" FontWeight="SemiBold" Margin="8,0,0,4"/>
                        <TextBlock Text="Daily Rate" Grid.Column="5" Grid.Row="0" FontWeight="SemiBold" Margin="8,0,0,4"/>

                        <TextBox x:Name="txtBrand" Grid.Column="0" Grid.Row="1" Height="34" Padding="6" Margin="0,0,6,0"/>
                        <TextBox x:Name="txtModel" Grid.Column="1" Grid.Row="1" Height="34" Padding="6" Margin="0,0,6,0"/>
                        <TextBox x:Name="txtPlate" Grid.Column="2" Grid.Row="1" Height="34" Padding="6" Margin="0,0,6,0"/>
                        <TextBox x:Name="txtYear"  Grid.Column="3" Grid.Row="1" Height="34" Padding="6" Margin="0,0,6,0"/>
                        <TextBox x:Name="txtColor" Grid.Column="4" Grid.Row="1" Height="34" Padding="6" Margin="0,0,6,0"/>
                        <TextBox x:Name="txtRate"  Grid.Column="5" Grid.Row="1" Height="34" Padding="6"/>

                        <!-- Buttons -->
                        <StackPanel Grid.Column="0" Grid.ColumnSpan="6" Grid.Row="2"
                                    Orientation="Horizontal" Margin="0,12,0,0">
                            <Button x:Name="btnAdd"          Content="➕ Add"            Width="100" Height="36" Margin="0,0,8,0" Background="#1E88E5" Foreground="White" BorderThickness="0" Click="btnAdd_Click"/>
                            <Button x:Name="btnModify"       Content="✏️ Modify"         Width="100" Height="36" Margin="0,0,8,0" Background="#FB8C00" Foreground="White" BorderThickness="0" Click="btnModify_Click"/>
                            <Button x:Name="btnDuplicate"    Content="📋 Duplicate"      Width="100" Height="36" Margin="0,0,8,0" Background="#43A047" Foreground="White" BorderThickness="0" Click="btnDuplicate_Click"/>
                            <Button x:Name="btnRemove"       Content="🗑️ Remove"         Width="100" Height="36" Margin="0,0,8,0" Background="#E53935" Foreground="White" BorderThickness="0" Click="btnRemove_Click"/>
                            <Button x:Name="btnClear"        Content="✖ Clear"           Width="80"  Height="36" Margin="0,0,8,0" Background="#9E9E9E" Foreground="White" BorderThickness="0" Click="btnClear_Click"/>
                            <Button x:Name="btnToggleStatus" Content="🔄 Toggle Status"  Width="130" Height="36" Background="#6A1B9A" Foreground="White" BorderThickness="0" Click="btnToggleStatus_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- DataGrid -->
            <Border Background="White" CornerRadius="10" Grid.Row="2" Padding="10">
                <DataGrid x:Name="dgVehicles"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          Background="White"
                          RowBackground="White"
                          AlternatingRowBackground="#F0F4FF"
                          SelectionChanged="dgVehicles_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"         Binding="{Binding Id}"          Width="45"/>
                        <DataGridTextColumn Header="Brand"      Binding="{Binding Brand}"        Width="*"/>
                        <DataGridTextColumn Header="Model"      Binding="{Binding Model}"        Width="*"/>
                        <DataGridTextColumn Header="Plate No."  Binding="{Binding PlateNumber}"  Width="*"/>
                        <DataGridTextColumn Header="Year"       Binding="{Binding Year}"         Width="60"/>
                        <DataGridTextColumn Header="Color"      Binding="{Binding Color}"        Width="*"/>
                        <DataGridTextColumn Header="Daily Rate" Binding="{Binding DailyRate, StringFormat={}{0:C}}" Width="*"/>
                        <DataGridTextColumn Header="Status"     Binding="{Binding Status}"       Width="*"/>
                        <DataGridTextColumn Header="Image"      Binding="{Binding ImagePath}"    Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Page>