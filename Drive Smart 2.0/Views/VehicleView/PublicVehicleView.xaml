<Window
    x:Class="Drive_Smart_2._0.Views.VehicleView.PublicVehicleView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:uc="clr-namespace:Drive_Smart_2._0.UserControls"
        Title="Vehicle Catalog"
        WindowStartupLocation="CenterScreen"
        Background="#F5F9FF">

    <Grid Width="1200" Height="700">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
            Background="#1565C0"
            VerticalAlignment="Stretch"
            Margin="0,0,5,0">

            <Grid Margin="15">

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Menu -->

                <uc:SideBar x:Name="SidebarMenu" Grid.Row="0"/>

                <!-- Logged User Section -->
                <uc:SidebarControl Grid.Row="1" Height="184" Margin="14,0,13,0" VerticalAlignment="Top"/>

            </Grid>

        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Background="White" CornerRadius="10" Grid.Row="0" Padding="15,0">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Vehicle Catalog"
                               FontSize="26" FontWeight="Bold"
                               VerticalAlignment="Center"
                               Grid.Column="0"/>

                    <Border Grid.Column="1"
                            Background="#F0F4FF"
                            BorderBrush="#C5D0E8"
                            BorderThickness="1"
                            CornerRadius="8"
                            VerticalAlignment="Center"
                            Padding="10,6">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🔍"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>
                            <TextBox x:Name="txtSearch"
                                     Width="240"
                                     Height="28"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="13"
                                     Foreground="#333"
                                     VerticalContentAlignment="Center"
                                     TextChanged="txtSearch_TextChanged"/>
                        </StackPanel>
                    </Border>

                </Grid>
            </Border>

            <!-- Scrollable Tile Grid -->
            <ScrollViewer Grid.Row="1" Margin="0,10,0,0"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="icVehicles">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="210" Margin="10"
                                    Background="White"
                                    CornerRadius="12"
                                    BorderBrush="#E0E0E0"
                                    BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="2"
                                                      Opacity="0.1" Color="Black"/>
                                </Border.Effect>
                                <StackPanel>
                                    <!-- Car Image -->
                                    <Border Height="140" CornerRadius="12,12,0,0"
                                            ClipToBounds="True" Background="#EEEEEE">
                                        <Image Source="{Binding FullImagePath}"
                                               Stretch="UniformToFill"/>
                                    </Border>

                                    <!-- Info -->
                                    <StackPanel Margin="12,10,12,12">
                                        <TextBlock Text="{Binding BrandModel}"
                                                   FontSize="15" FontWeight="Bold"
                                                   Foreground="#1A1A1A"/>
                                        <TextBlock Text="{Binding PlateNumber}"
                                                   FontSize="12" Foreground="#888"
                                                   Margin="0,2,0,0"/>
                                        <Grid Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Year" FontSize="10" Foreground="#AAAAAA"/>
                                                <TextBlock Text="{Binding Year}" FontSize="13" FontWeight="SemiBold"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Color" FontSize="10" Foreground="#AAAAAA"/>
                                                <TextBlock Text="{Binding Color}" FontSize="13" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Grid>
                                        <Separator Margin="0,8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Daily Rate" FontSize="10" Foreground="#AAAAAA"/>
                                                <TextBlock Text="{Binding DailyRate, StringFormat={}{0:N2} LKR}"
                                                           FontSize="15" FontWeight="Bold" Foreground="#1565C0"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" CornerRadius="6" Padding="8,4"
                                                    Background="{Binding StatusColor}">
                                                <TextBlock Text="{Binding Status}"
                                                           FontSize="11" Foreground="White"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Frame x:Name="PublicVehicleViewFrame"
                   Grid.Column="0"
                   Grid.ColumnSpan="2"
                   NavigationUIVisibility="Hidden"
                   Visibility="Collapsed"/>

    </Grid>
</Window>