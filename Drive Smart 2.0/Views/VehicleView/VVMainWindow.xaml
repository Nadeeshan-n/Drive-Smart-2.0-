<Window x:Class="Drive_Smart_2._0.Views.VehicleView.VVMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Drive_Smart_2._0.Views.VehicleView"
        mc:Ignorable="d"
        Title="Navigation Window" Height="700" Width="1200">
    <Grid>
        <Button x:Name="adminbutton" Content="Admin Page" HorizontalAlignment="Left" Margin="29,46,0,0" VerticalAlignment="Top" Height="54" Width="125" Click="Button_Click"/>
        <Button x:Name="pubbut" Content="Public Page" HorizontalAlignment="Left" Margin="182,46,0,0" VerticalAlignment="Top" Height="54" Width="125" Click="Button_Click2"/>
        <Button x:Name="help" Content="Help Page" HorizontalAlignment="Left" Margin="336,46,0,0" VerticalAlignment="Top" Height="54" Width="125" Click="Button_Click3"/>
        
        <Frame x:Name="VVMainWindowFrame"
           Grid.Column="0"
           Grid.ColumnSpan="2"
           NavigationUIVisibility="Hidden"
           Visibility="Collapsed"/>
        <Button x:Name="help_Copy" Content="Maintanance" HorizontalAlignment="Left" Margin="494,46,0,0" VerticalAlignment="Top" Height="54" Width="125" Click="Button_Click4"/>
    </Grid>
    
    
    
</Window>
