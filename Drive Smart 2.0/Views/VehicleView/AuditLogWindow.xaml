<Window x:Class="Drive_Smart_2._0.Views.VehicleView.AuditLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Maintenance Audit Log"
        Height="500" Width="900"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Maintenance Audit Log — All Changes"
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
        <DataGrid x:Name="dgAudit" Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  AlternatingRowBackground="#F0F4FF">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time"       Binding="{Binding ChangedAt}"      Width="130"/>
                <DataGridTextColumn Header="Plate"      Binding="{Binding VehiclePlate}"   Width="90"/>
                <DataGridTextColumn Header="Type"       Binding="{Binding MaintenanceType}" Width="*"/>
                <DataGridTextColumn Header="Field"      Binding="{Binding FieldChanged}"   Width="*"/>
                <DataGridTextColumn Header="Old Value"  Binding="{Binding OldValue}"       Width="*"/>
                <DataGridTextColumn Header="New Value"  Binding="{Binding NewValue}"       Width="*"/>
                <DataGridTextColumn Header="Changed By" Binding="{Binding ChangedBy}"      Width="90"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>