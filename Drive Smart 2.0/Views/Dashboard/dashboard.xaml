<Window x:Class="Drive_Smart_2._0.models.dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="Vehicle Rental Dashboard"
        Height="900" Width="1300"
        MinHeight="700" MinWidth="1100"
        Background="#F5F9FF">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="97*"/>
            <ColumnDefinition Width="303*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Width="220"
                Background="#1565C0"
                HorizontalAlignment="Left">

            <StackPanel Margin="15">

                <TextBlock Text="RENTAL SYSTEM"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,20,0,30"/>

                <Button Content="Dashboard"
                        Height="45"
                        Margin="0,5"
                        Background="#1E88E5"
                        Foreground="White"
                        BorderThickness="0"/>

                <Button Content="Vehicles"
                        Height="45"
                        Margin="0,5"
                        Background="#1565C0"
                        Foreground="White"
                        BorderThickness="0" Click="Button_Click"/>

                <Button Content="Customers"
                        Height="45"
                        Margin="0,5"
                        Background="#1565C0"
                        Foreground="White"
                        BorderThickness="0"/>

                <Button Content="Bookings"
                        Height="45"
                        Margin="0,5"
                        Background="#1565C0"
                        Foreground="White"
                        BorderThickness="0"/>

                <Button Content="Payments"
                        Height="45"
                        Margin="0,5"
                        Background="#1565C0"
                        Foreground="White"
                        BorderThickness="0"/>

                <Button Content="Reports"
                        Height="45"
                        Margin="0,5"
                        Background="#1565C0"
                        Foreground="White"
                        BorderThickness="0"/>
            </StackPanel>

        </Border>

        <!-- Main Content -->
        <Grid Margin="240,20,20,20" Grid.ColumnSpan="2">

            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="White"
                    CornerRadius="10">

                <Grid Margin="20,0">
                    <TextBlock Text="Dashboard"
                               FontSize="28"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>

                    <TextBlock Text="Welcome Admin"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="16"
                               Foreground="Gray"/>
                </Grid>

            </Border>

            <!-- Scrollable body: stats, revenue charts, recent rentals -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Margin="0,20,0,0">
            <StackPanel>

            <!-- Statistics Cards -->
            <Grid Height="150" Margin="0,0,0,20">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="5"
                        Background="#2196F3"
                        CornerRadius="12">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="totvehecles" Text="150"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Total Vehicles"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Margin="5"
                        Background="#2196F3"
                        CornerRadius="12">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="availablevehecletxt" Text="95"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Available"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Margin="5"
                        Background="#2196F3"
                        CornerRadius="12">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="rentedvehecletxt" Text="45"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Currently Rented"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3"
                        Margin="5"
                        Background="#2196F3"
                        CornerRadius="12">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="monthlyincometxt" Text="Rs. 250K"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Monthly Revenue"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </Grid>

            <!-- Revenue Charts -->
            <Grid Height="320" Margin="0,0,0,20">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Monthly Revenue Trend -->
                <Border Grid.Column="0"
                        Margin="0,0,10,0"
                        Background="White"
                        CornerRadius="12"
                        Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Monthly Revenue Trend"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <lvc:CartesianChart x:Name="revenueTrendChart"
                                            Grid.Row="1"
                                            TooltipPosition="Top"/>
                    </Grid>
                </Border>

                <!-- Revenue by Category -->
                <Border Grid.Column="1"
                        Margin="10,0,0,0"
                        Background="White"
                        CornerRadius="12"
                        Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Revenue by Category"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <lvc:CartesianChart x:Name="revenueCategoryChart"
                                            Grid.Row="1"
                                            TooltipPosition="Top"/>
                    </Grid>
                </Border>

            </Grid>

            <!-- Recent Rentals Table -->
            <Border
                    Background="White"
                    CornerRadius="12"
                    Padding="15">

                <StackPanel>

                    <TextBlock Text="Recent Rentals"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <DataGrid x:Name="dgVehicles"
          AutoGenerateColumns="False"
          Height="300"
          IsReadOnly="True"
          AlternatingRowBackground="#F5F9FF"
          GridLinesVisibility="Horizontal"
          HeadersVisibility="Column">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"
                            Binding="{Binding Id}"
                            Width="50"/>
                            <DataGridTextColumn Header="Brand"
                            Binding="{Binding Brand}"
                            Width="100"/>
                            <DataGridTextColumn Header="Model"
                            Binding="{Binding Model}"
                            Width="120"/>
                            <DataGridTextColumn Header="Plate Number"
                            Binding="{Binding PlateNumber}"
                            Width="120"/>
                            <DataGridTextColumn Header="Year"
                            Binding="{Binding Year}"
                            Width="60"/>
                            <DataGridTextColumn Header="Daily Rate (Rs.)"
                            Binding="{Binding DailyRate}"
                            Width="120"/>

                            <!-- Status column with color -->
                            <DataGridTemplateColumn Header="Status" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="8"
                            Padding="6,2"
                            HorizontalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Available">
                                                            <Setter Property="Background" Value="#E8F5E9"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Rented">
                                                            <Setter Property="Background" Value="#FFF3E0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Status}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Available">
                                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Rented">
                                                                <Setter Property="Foreground" Value="#E65100"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>

            </Border>

            </StackPanel>
            </ScrollViewer>

        </Grid>

        <Frame x:Name="DashboardWindowFrame"
       Grid.Column="0"
       Grid.ColumnSpan="2"
       NavigationUIVisibility="Hidden"
       Visibility="Collapsed"/>

    </Grid>
</Window>