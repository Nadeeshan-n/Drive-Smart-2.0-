<Window x:Class="Drive_Smart_2._0.Views.Auth.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Password"
        Width="420" Height="423"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">

    <Grid Background="White" Margin="30,30,30,6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="🔒 Change Your Password"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#111827"/>
            <TextBlock Text="You must set a new password before continuing."
                       FontSize="13"
                       Foreground="#6B7280"
                       Margin="0,6,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- New Password -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="New Password"
                       FontWeight="SemiBold"
                       FontSize="14"
                       Margin="0,0,0,6"/>
            <Border Height="38"
                    BorderBrush="#C7D2E0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10,0">
                <PasswordBox x:Name="PwdNew"
                             BorderThickness="0"
                             Background="Transparent"
                             VerticalContentAlignment="Center"
                             FontSize="14"/>
            </Border>
        </StackPanel>

        <!-- Confirm Password -->
        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Text="Confirm Password"
                       FontWeight="SemiBold"
                       FontSize="14"
                       Margin="0,0,0,6"/>
            <Border Height="38"
                    BorderBrush="#C7D2E0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10,0">
                <PasswordBox x:Name="PwdConfirm"
                             BorderThickness="0"
                             Background="Transparent"
                             VerticalContentAlignment="Center"
                             FontSize="14"/>
            </Border>
        </StackPanel>

        <!-- Rules -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="Password must be at least 6 characters"
                       FontSize="12"
                       Foreground="#6B7280"/>
            <TextBlock Text="Cannot start with DS@ (default password pattern)"
                       FontSize="12"
                       Foreground="#6B7280"/>
            <TextBlock Text="New and confirm password must match"
                       FontSize="12"
                       Foreground="#6B7280"/>
        </StackPanel>

        <!-- Save Button -->
        <Button Grid.Row="6"
                x:Name="BtnSave"
                Content="Save New Password"
                Height="42"
                Background="#1565C0"
                Foreground="White"
                BorderThickness="0"
                FontSize="14"
                FontWeight="SemiBold"
                Cursor="Hand"
                Click="BtnSave_Click"/>
    </Grid>
</Window>