<Window x:Class="Drive_Smart_2._0.Views.Auth.login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Drive_Smart_2._0.Views.Auth"
        mc:Ignorable="d"
        Title="Drive Smart  — Login"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Grid>
        <!-- Background gradient -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF0D47A1" Offset="0"/>
                <GradientStop Color="#FF1976D2" Offset="0.5"/>
                <GradientStop Color="#FF42A5F5" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Optional subtle pattern overlay -->
        <Rectangle Opacity="0.04">
            <Rectangle.Fill>
                <DrawingBrush TileMode="Tile"
                              Viewport="0,0,40,40"
                              ViewportUnits="Absolute">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing Brush="White">
                            <GeometryDrawing.Geometry>
                                <EllipseGeometry RadiusX="1" RadiusY="1"/>
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Login Card -->
        <Border Width="480"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                CornerRadius="16"
                Background="White">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30"
                                  ShadowDepth="8"
                                  Opacity="0.2"
                                  Color="#000000"/>
            </Border.Effect>

            <StackPanel Margin="40,36,40,40">

                <!-- Logo / Header -->
                <Border Background="#FF1565C0"
                        CornerRadius="12"
                        Padding="20,18"
                        Margin="0,0,0,28">
                    <StackPanel>
                        <TextBlock Text="🚗  Drive Smart"
                                   HorizontalAlignment="Center"
                                   Foreground="White"
                                   FontSize="26"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Car Rental Management System"
                                   HorizontalAlignment="Center"
                                   Foreground="#BBDEFB"
                                   FontSize="13"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Username -->
                <TextBlock Text="Username"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           Margin="0,0,0,6"/>
                <Border Height="42"
                        Background="#F7FAFF"
                        BorderBrush="#C7D2E0"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12,0"
                        Margin="0,0,0,18">
                    <TextBox x:Name="usernameBox"
                             BorderThickness="0"
                             Background="Transparent"
                             VerticalContentAlignment="Center"
                             FontSize="14"
                             Foreground="#111827"/>
                </Border>

                <!-- Password -->
                <TextBlock Text="Password"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           Margin="0,0,0,6"/>
                <Border Height="42"
                        Background="#F7FAFF"
                        BorderBrush="#C7D2E0"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12,0"
                        Margin="0,0,0,10">
                    <PasswordBox x:Name="loginPassword"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalContentAlignment="Center"
                                 FontSize="14"/>
                </Border>

                <!-- Error message — hidden by default -->
                <TextBlock x:Name="TxtError"
                           Text="Invalid username or password."
                           Foreground="#C62828"
                           FontSize="13"
                           Margin="0,0,0,10"
                           Visibility="Collapsed"/>

                <!-- Login Button -->
                <Button x:Name="loginButton"
                        Content="Log In"
                        Height="44"
                        Background="#FF1565C0"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="15"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Margin="0,10,0,0"
                        Click="LoginButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="10"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FF0D47A1"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#FF002171"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Footer -->
                <TextBlock Text="Only authorized employees can access this system."
                           HorizontalAlignment="Center"
                           Foreground="#9CA3AF"
                           FontSize="12"
                           Margin="0,16,0,0"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>