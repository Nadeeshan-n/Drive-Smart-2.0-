<Window x:Class="Drive_Smart_2._0.Views.Auth.login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Drive_Smart_2._0.Views.Auth"
        mc:Ignorable="d"
        Title="login"
        Height="700"
        Width="1200"
        SizeToContent="Manual"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid>
        <Border Width="530"
                MaxWidth="550"
                MinWidth="450"
                Height="463"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                CornerRadius="10">
            <Border.Background>
                <SolidColorBrush Color="#FFEEF0FF" Opacity="0.75"/>
            </Border.Background>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="112"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Width="495"
                        Height="100"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,12,0,0"
                        Background="#FF1565C0"
                        BorderBrush="#FF002A71"
                        BorderThickness="1"
                        CornerRadius="20">
                    <TextBlock Text=" Employee Login"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontSize="36"
                               FontWeight="Bold"/>
                </Border>

                <StackPanel Grid.Row="1"
                            Width="455"
                            MaxWidth="455"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,24,0,0">
                    <Label Content="User Name"
                           Padding="0"
                           Foreground="Black"
                           FontSize="16"/>

                    <Border Height="40"
                            Margin="0,6,0,0"
                            Background="#FFF6F8FE"
                            BorderBrush="#FFBFBFBF"
                            BorderThickness="1"
                            CornerRadius="10">
                        <TextBox x:Name="usernameBox"
                                 Width="439"
                                 Height="26"
                                 Margin="5,0"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 TextWrapping="Wrap"
                                 Background="#FFF6F8FE"
                                 FontFamily="Tahoma"
                                 FontSize="16"
                                 BorderBrush="{x:Null}"
                                 SelectionBrush="{x:Null}"
                                 SelectionTextBrush="{x:Null}"/>
                    </Border>

                    <Label Content="Password"
                           Margin="0,22,0,0"
                           Padding="0"
                           Foreground="Black"
                           FontSize="16"/>

                    <Border Height="40"
                            Margin="0,6,0,0"
                            Background="#FFF6F8FE"
                            BorderBrush="#FFC7C7C7"
                            BorderThickness="1"
                            CornerRadius="10">
                        <PasswordBox x:Name="loginPassword"
                                     Width="428"
                                     Height="23"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Background="#FFF6F8FE"
                                     BorderBrush="{x:Null}"/>
                    </Border>

                    <Button x:Name="loginButton"
                            Content="Log In"
                            Width="454"
                            Height="38"
                            HorizontalAlignment="Center"
                            Margin="0,47,0,0"
                            Background="#FF1565C0"
                            BorderBrush="{x:Null}"
                            FontSize="18"
                            Foreground="#FFFFFEFF"
                            FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
