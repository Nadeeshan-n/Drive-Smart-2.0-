<Window x:Class="Drive_Smart_2._0.Views.Auth.EmployeeRegister"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Drive_Smart_2._0.Views.Auth"
        xmlns:uc="clr-namespace:Drive_Smart_2._0.UserControls"
        mc:Ignorable="d"
        Title="Employee Registration"
        Width="1200"
        Height="700"
        MinWidth="900"
        MinHeight="620"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen"
        SnapsToDevicePixels="True">


    <Window.Resources>


        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="InputBorderStyle" TargetType="Border">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#FFF6F8FE"/>
            <Setter Property="BorderBrush" Value="#FF989898"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <Style x:Key="FormTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="Background" Value="{x:Null}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="MinHeight" Value="24"/>
        </Style>

        <Style x:Key="FormDatePickerStyle" TargetType="DatePicker">
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="Background" Value="{x:Null}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="MinHeight" Value="28"/>
        </Style>

        <Style x:Key="FormComboBoxStyle" TargetType="ComboBox">
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="Background" Value="{x:Null}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="MinHeight" Value="28"/>
        </Style>
    </Window.Resources>

    <Grid Background="White" Margin="0,0,0,-6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="0*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0"
        Background="#1565C0"
        VerticalAlignment="Stretch"
        Margin="0,0,5,0">

            <Grid Margin="15">

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Menu -->
                <uc:SideBar Grid.Row="0"/>

                <!-- Logged User Section -->
                <uc:SidebarControl Grid.Row="1"/>

            </Grid>

        </Border>

        <Grid Grid.Column="1"
              Margin="20,16,9,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Employee Registration"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"
                                          MinWidth="300"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"
                                          MinWidth="300"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Employee ID" Style="{StaticResource FormLabelStyle}"/>
                            <!-- FIX 1: Added TextChanged="EmployeeID_TextChanged" -->
                            <Border x:Name="EmployeeIDBorder" Style="{StaticResource InputBorderStyle}">
                                <TextBox x:Name="EmployeeID"
                                         Style="{StaticResource FormTextBoxStyle}"
                                         TextChanged="EmployeeID_TextChanged"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="2">
                            <TextBlock Text="Full Name" Style="{StaticResource FormLabelStyle}"/>
                            <Border x:Name="FullNameBorder" Style="{StaticResource InputBorderStyle}">
                                <TextBox x:Name="FullName"
                                         Style="{StaticResource FormTextBoxStyle}"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="4">
                            <TextBlock Text="NIC" Style="{StaticResource FormLabelStyle}"/>
                            <!-- FIX 2: Added TextChanged="NIC_TextChanged" -->
                            <Border x:Name="NICBorder" Style="{StaticResource InputBorderStyle}">
                                <TextBox x:Name="NIC"
                                         Style="{StaticResource FormTextBoxStyle}"
                                         TextChanged="NIC_TextChanged"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="6">
                            <TextBlock Text="Gender" Style="{StaticResource FormLabelStyle}"/>
                            <Border x:Name="GenderBorder" Style="{StaticResource InputBorderStyle}">
                                <ComboBox x:Name="Gender"
                                          Style="{StaticResource FormComboBoxStyle}">
                                    <ComboBoxItem Content="-- Select Gender --" IsSelected="True"/>
                                    <ComboBoxItem Content="Male"/>
                                    <ComboBoxItem Content="Female"/>
                                    <ComboBoxItem Content="Other"/>
                                    <ComboBoxItem/>
                                </ComboBox>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="8">
                            <TextBlock Text="Email Address" Style="{StaticResource FormLabelStyle}"/>
                            <Border x:Name="EmailBorder" Style="{StaticResource InputBorderStyle}">
                                <TextBox x:Name="EmailAddress"
                                         Style="{StaticResource FormTextBoxStyle}"
                                         TextChanged="EmailAddress_TextChanged"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="10">
                            <TextBlock Text="Phone Number" Style="{StaticResource FormLabelStyle}"/>
                            <Border x:Name="PhoneNumberBorder" Style="{StaticResource InputBorderStyle}">
                                <TextBox x:Name="PhoneNumber"
                                         Style="{StaticResource FormTextBoxStyle}"
                                         TextChanged="PhoneNumber_TextChanged"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="12">
                            <TextBlock Text="Date Of Birth" Style="{StaticResource FormLabelStyle}"/>
                            <Border x:Name="DateOfBirthBorder" Style="{StaticResource InputBorderStyle}">
                                <DatePicker x:Name="DateOfBirth"
                                            Style="{StaticResource FormDatePickerStyle}"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Position" Style="{StaticResource FormLabelStyle}"/>
                            <Border Style="{StaticResource InputBorderStyle}">
                                <ComboBox x:Name="Position" Width="420" Background="{x:Null}" BorderBrush="{x:Null}" Height="24" VerticalAlignment="Center" Text="Select the Position">
                                    <ComboBoxItem Background="{x:Null}" BorderBrush="{x:Null}" Content="-- Select Position --" IsSelected="True"/>
                                    <ComboBoxItem Background="{x:Null}" BorderBrush="{x:Null}" Content="Admin"/>
                                    <ComboBoxItem Background="{x:Null}" BorderBrush="{x:Null}" Content="Manager"/>
                                    <ComboBoxItem Background="{x:Null}" BorderBrush="{x:Null}" Content="Staff"/>
                                    <ComboBoxItem/>
                                </ComboBox>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="2">
                            <TextBlock Text="Salary"
                                       IsEnabled="False"
                                       Style="{StaticResource FormLabelStyle}"/>
                            <Border x:Name="SalaryBorder" Style="{StaticResource InputBorderStyle}">
                                <TextBox x:Name="Salary"
                                         Style="{StaticResource FormTextBoxStyle}"
                                         TextChanged="Salary_TextChanged"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="4">
                            <TextBlock Text="Joining Date" Style="{StaticResource FormLabelStyle}"/>
                            <Border Style="{StaticResource InputBorderStyle}">
                                <DatePicker x:Name="JoiningDate"
                                            Style="{StaticResource FormDatePickerStyle}"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="6">
                            <TextBlock Text="Addresses" Style="{StaticResource FormLabelStyle}"/>
                            <Border Height="117"
                                    Style="{StaticResource InputBorderStyle}"
                                    Padding="10">
                                <TextBox x:Name="Address"
                                         Style="{StaticResource FormTextBoxStyle}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         VerticalContentAlignment="Top"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>
            </ScrollViewer>

            <Grid Grid.Row="2"
                  Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="267"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="267"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- FIX 3: Added Click="Reset_Click" so the Reset button actually calls the handler -->
                <Button x:Name="Reset"
                        Grid.Column="1"
                        Content="Reset"
                        Height="39"
                        Background="White"
                        BorderBrush="#FF1565C0"
                        Foreground="#FF1565C0"
                        FontWeight="Bold"
                        FontSize="14"
                        Click="Reset_Click"
                        IsCancel="True"/>

                <!-- FIX 4: Added Click="Employee_Register_Click" so the Register button works -->
                <Button x:Name="Employee_Register"
                        Grid.Column="3"
                        Content="Register Employee"
                        Height="39"
                        Background="#FF1565C0"
                        BorderBrush="{x:Null}"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="14"
                        Click="Employee_Register_Click"/>
            </Grid>
        </Grid>
        <Grid Grid.Column="1" Margin="0,0,111,144"/>
        <Grid Grid.Column="1" Margin="0,0,10,0"/>
    </Grid>
</Window>
