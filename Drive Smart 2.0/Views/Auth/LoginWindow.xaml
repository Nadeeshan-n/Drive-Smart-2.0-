<Window x:Class="Drive_Smart_2._0.Views.Auth.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Drive_Smart_2._0.Views.Auth"
        mc:Ignorable="d"
        Title="LoginWindow" Height="507" Width="800">
    <Grid>
        <Image HorizontalAlignment="Left" Height="422" Margin="7,10,0,0" VerticalAlignment="Top" Width="793" Source="/Views/Auth/ChatGPT Image May 29, 2026, 03_23_41 PM.png" Stretch="UniformToFill"/>
        <Rectangle HorizontalAlignment="Left" Height="421" Margin="146,0,0,0" VerticalAlignment="Center" Width="516" Fill="#FF02295D" Opacity="0.75" RadiusY="10" RadiusX="10"/>
        <Rectangle HorizontalAlignment="Left" Height="77" Margin="146,35,0,0" VerticalAlignment="Top" Width="516" RenderTransformOrigin="0.5,0.5" Fill="#FF031932" RadiusX="10" RadiusY="10">
            <Rectangle.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleX="0"/>
                    <RotateTransform/>
                    <TranslateTransform X="0"/>
                </TransformGroup>
            </Rectangle.RenderTransform>
        </Rectangle>
        <Label Content="DRIVE SMART" HorizontalAlignment="Left" Margin="293,50,0,0" VerticalAlignment="Top" Cursor="" FontFamily="Tahoma" FontWeight="Bold" FontSize="30" Foreground="#FFFDFDFD"/>
        <Label Content="User Name" HorizontalAlignment="Left" Margin="169,147,0,0" VerticalAlignment="Top" Foreground="#FFFDFDFD" FontSize="16" FontFamily="Tahoma"/>
        <Label Content="Password" HorizontalAlignment="Left" Margin="169,0,0,0" VerticalAlignment="Center" Foreground="#FFFDFDFD" FontSize="16" FontFamily="Tahoma"/>
        <Rectangle HorizontalAlignment="Left" Height="40" Margin="169,173,0,0" VerticalAlignment="Top" Width="455" RenderTransformOrigin="0.5,0.5" Fill="#FFF6F8FE" RadiusX="10" RadiusY="10" Stroke="#FF041A33">
            <Rectangle.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleX="0"/>
                    <RotateTransform/>
                    <TranslateTransform X="0"/>
                </TransformGroup>
            </Rectangle.RenderTransform>
        </Rectangle>
        <TextBox x:Name="usernameLable" HorizontalAlignment="Left" Margin="174,178,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="439" Height="26" Background="#FFF6F8FE" FontFamily="Tahoma" FontSize="16" BorderBrush="{x:Null}"/>
        <Rectangle HorizontalAlignment="Left" Height="40" Margin="169,261,0,0" VerticalAlignment="Top" Width="455" RenderTransformOrigin="0.5,0.5" Fill="#FFF6F8FE" RadiusX="10" RadiusY="10" Stroke="#FF041A33">
            <Rectangle.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleX="0"/>
                    <RotateTransform/>
                    <TranslateTransform X="0"/>
                </TransformGroup>
            </Rectangle.RenderTransform>
        </Rectangle>
        <TextBox x:Name="passwordLable" HorizontalAlignment="Left" Margin="184,268,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="426" Height="26" Background="#FFF6F8FE" FontFamily="Tahoma" FontSize="16" BorderBrush="{x:Null}"/>
        <Button x:Name="loginButton" Content="Log In" HorizontalAlignment="Left" Margin="169,365,0,0" VerticalAlignment="Top" Width="455" Background="#FF0149C2" Height="31" BorderBrush="{x:Null}" FontFamily="Tahoma" FontSize="18" Foreground="#FFFFFEFF" FontWeight="Bold"/>
        <TextBlock HorizontalAlignment="Left" Margin="967,0,0,0" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Center"/>
        <Label Content="For new employees," HorizontalAlignment="Left" Margin="243,401,0,0" VerticalAlignment="Top" Foreground="#FFFDFDFD" FontFamily="Tahoma"/>
    </Grid>
</Window>
